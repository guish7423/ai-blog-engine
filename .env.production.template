# =============================================================================
# CrossBlog — Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all secrets.
# NEVER commit .env to version control.

# --- LLM API (DeepSeek) ---
# LLM_API_KEY is checked first, then DEEPSEEK_API_KEY as fallback
LLM_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key  # Alternative env var name
LLM_API_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_API_MOCK=false

# --- Pricing (production values) ---
PRICE_PER_POST=1.99
MONTHLY_SUB=29.99
ANNUAL_SUB=249.99

# --- Production Settings ---
HOST=0.0.0.0
PORT=8002
WORKERS=2
DEBUG=false
